rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'hurmakilhan55@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'
      );
    }
    
    function isTechnician() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TECHNICIAN'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // --- Customer Data ---
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Services ---
    match /services/{serviceId} {
      allow read: if isAdmin() || (isSignedIn() && existing().technicianId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && existing().technicianId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }
  }
}
